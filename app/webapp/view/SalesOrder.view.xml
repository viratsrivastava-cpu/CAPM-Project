<mvc:View
    controllerName="zsd.controller.SalesOrder"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">

<Page title="Sales Order Management System" showNavButton="true" navButtonPress="onNavHome">

<!-- ================= OPERATION SELECTION ================= -->
<Panel headerText="Select Operation"
       class="sapUiLargeMargin sapUiResponsiveMargin"
       visible="{/showOperationSelector}">

    <VBox alignItems="Center" class="sapUiMediumMarginTop sapUiMediumMarginBottom">
        <HBox justifyContent="Center">
            <Button text="Create"
                    type="Accept"
                    icon="sap-icon://add"
                    press="onCreate"
                    width="150px"
                    class="sapUiSmallMargin"/>
            <Button text="Read"
                    type="Emphasized"
                    icon="sap-icon://search"
                    press="onRead"
                    width="150px"
                    class="sapUiSmallMargin"/>
            <Button text="Update"
                    icon="sap-icon://edit"
                    press="onUpdate"
                    width="150px"
                    class="sapUiSmallMargin"/>
            <Button text="Delete"
                    type="Reject"
                    icon="sap-icon://delete"
                    press="onDelete"
                    width="150px"
                    class="sapUiSmallMargin"/>
        </HBox>
    </VBox>
</Panel>


<!-- ================= CREATE SALES ORDER ================= -->
<Panel headerText="Create Sales Order"
       class="sapUiLargeMargin sapUiResponsiveMargin"
       visible="{/showCreatePanel}">

    <Toolbar>
        <Button text="Back" icon="sap-icon://nav-back" press="onBack"/>
    </Toolbar>

    <f:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout"
        columnsXL="2"
        columnsL="1"
        columnsM="1">
        <f:content>
            <Label text="VBELN — Sales Order No" required="true"/>
            <Input value="{/createPayload/VBELN}" placeholder="e.g. 0000000001"/>

            <Label text="ERDAT — Creation Date"/>
            <Input value="{/createPayload/ERDAT}" placeholder="e.g. 2024-01-01"/>

            <Label text="KUNNR — Customer No"/>
            <Input value="{/createPayload/KUNNR}" placeholder="e.g. CUST001"/>

            <Label text="ERNAM — Created By"/>
            <Input value="{/createPayload/ERNAM}" placeholder="e.g. ADMIN"/>
        </f:content>
    </f:SimpleForm>

    <Toolbar>
        <Button text="Save"
                type="Accept"
                icon="sap-icon://save"
                press="onSave"/>
    </Toolbar>
</Panel>


<!-- ================= READ SALES ORDER ================= -->
<Panel headerText="View Sales Orders"
       class="sapUiLargeMargin sapUiResponsiveMargin"
       visible="{/showReadPanel}">

    <Toolbar>
        <Button text="Back" icon="sap-icon://nav-back" press="onBack"/>
    </Toolbar>

    <f:SimpleForm layout="ResponsiveGridLayout">
        <f:content>
            <Label text="VBELN — Sales Order No"/>
            <HBox>
                <Input value="{/readVBELN}" placeholder="Enter full or partial VBELN"/>
                <Button icon="sap-icon://search"
                        text="Search"
                        press="onSearchSalesOrder"
                        class="sapUiSmallMarginBegin"/>
            </HBox>
        </f:content>
    </f:SimpleForm>

    <Panel headerText="Sales Orders" visible="{/showReadResult}">
        <Toolbar>
            <Button text="Add Item"
                    icon="sap-icon://add"
                    press="onOpenCreateItemDialog"
                    class="sapUiSmallMargin"/>
        </Toolbar>
        <t:Table
            id="idTable"
            rows="{/salesOrders}"
            visibleRowCount="5"
            selectionMode="None">
            <t:columns>
                <t:Column>
                    <Label text="VBELN"/>
                    <t:template><Text text="{VBELN}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="ERDAT"/>
                    <t:template><Text text="{ERDAT}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="KUNNR"/>
                    <t:template><Text text="{KUNNR}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="ERNAM"/>
                    <t:template><Text text="{ERNAM}"/></t:template>
                </t:Column>
            </t:columns>
        </t:Table>
    </Panel>
</Panel>


<!-- ================= UPDATE SALES ORDER ================= -->
<Panel headerText="Update Sales Order"
       class="sapUiLargeMargin sapUiResponsiveMargin"
       visible="{/showUpdatePanel}">

    <Toolbar>
        <Button text="Back" icon="sap-icon://nav-back" press="onBack"/>
    </Toolbar>

    <f:SimpleForm layout="ResponsiveGridLayout">
        <f:content>
            <Label text="VBELN — Sales Order No"/>
            <HBox>
                <Input value="{/searchVBELN}" placeholder="Enter full or partial VBELN"/>
                <Button text="Search &amp; Load"
                        icon="sap-icon://search"
                        press="onEditSalesOrder"
                        class="sapUiSmallMarginBegin"/>
            </HBox>
        </f:content>
    </f:SimpleForm>

    <Panel visible="{/editMode}" headerText="Edit Sales Order">
        <f:SimpleForm layout="ResponsiveGridLayout">
            <f:content>
                <Label text="VBELN"/>
                <Text text="{/editPayload/VBELN}"/>

                <Label text="ERDAT — Creation Date"/>
                <Input value="{/editPayload/ERDAT}"/>

                <Label text="KUNNR — Customer No"/>
                <Input value="{/editPayload/KUNNR}"/>

                <Label text="ERNAM — Created By"/>
                <Input value="{/editPayload/ERNAM}"/>
            </f:content>
        </f:SimpleForm>
        <Toolbar>
            <Button text="Update"
                    type="Accept"
                    icon="sap-icon://save"
                    press="onUpdateSalesOrder"/>
            <Button text="Cancel"
                    type="Reject"
                    icon="sap-icon://cancel"
                    press="onCancelEdit"/>
        </Toolbar>
    </Panel>
</Panel>


<!-- ================= DELETE SALES ORDER ================= -->
<Panel headerText="Delete Sales Order"
       class="sapUiLargeMargin sapUiResponsiveMargin"
       visible="{/showDeletePanel}">

    <Toolbar>
        <Button text="Back" icon="sap-icon://nav-back" press="onBack"/>
    </Toolbar>

    <f:SimpleForm>
        <f:content>
            <Label text="VBELN — Sales Order No"/>
            <HBox>
                <Input value="{/deleteVBELN}" placeholder="Enter full or partial VBELN"/>
                <Button text="Search"
                        icon="sap-icon://search"
                        press="onDeleteSearch"
                        class="sapUiSmallMarginBegin"/>
            </HBox>
        </f:content>
    </f:SimpleForm>

    <Panel visible="{/showDeleteResult}" headerText="Sales Orders">
        <t:Table
            id="idDeleteTable"
            rows="{/salesOrders}"
            selectionMode="MultiToggle"
            visibleRowCount="5">
            <t:columns>
                <t:Column>
                    <Label text="VBELN"/>
                    <t:template><Text text="{VBELN}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="ERDAT"/>
                    <t:template><Text text="{ERDAT}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="KUNNR"/>
                    <t:template><Text text="{KUNNR}"/></t:template>
                </t:Column>
                <t:Column>
                    <Label text="ERNAM"/>
                    <t:template><Text text="{ERNAM}"/></t:template>
                </t:Column>
            </t:columns>
        </t:Table>
        <Toolbar>
            <Button text="Delete Selected"
                    type="Reject"
                    icon="sap-icon://delete"
                    press="onDeleteSelected"/>
        </Toolbar>
    </Panel>
</Panel>


<!-- ================= CREATE SALES ORDER ITEM DIALOG ================= -->
<Dialog id="createItemDialog"
        title="Create Sales Order Item"
        contentWidth="500px">
    <customHeader>
        <Bar>
            <contentLeft>
                <Button icon="sap-icon://nav-back" press="onCloseItemDialog"/>
            </contentLeft>
            <contentMiddle>
                <Title text="Create Sales Order Item"/>
            </contentMiddle>
        </Bar>
    </customHeader>
    <content>
        <VBox class="sapUiSmallMargin">
            <Label text="VBELN — Sales Order No" required="true" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/VBELN}" placeholder="e.g. 0000000001"/>

            <Label text="POSNR — Line Item No" required="true" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/POSNR}" placeholder="e.g. 000010"/>

            <Label text="MATNR — Material No" required="true" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/MATNR}" placeholder="e.g. MAT0001"/>

            <Label text="MATKL — Material Group" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/MATKL}" placeholder="e.g. PLASTICS"/>

            <Label text="MENGE — Quantity" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/MENGE}" placeholder="e.g. 5" type="Number"/>

            <Label text="MEINS — Unit" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/MEINS}" placeholder="e.g. EA"/>

            <Label text="NETPR — Net Price" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/NETPR}" placeholder="e.g. 25000" type="Number"/>

            <Label text="PEINH — Currency" class="sapUiSmallMarginTop"/>
            <Input value="{/itemPayload/PEINH}" placeholder="e.g. INR"/>
        </VBox>
    </content>
    <beginButton>
        <Button text="Create"
                type="Emphasized"
                press="onSaveItem"/>
    </beginButton>
    <endButton>
        <Button text="Cancel"
                press="onCloseItemDialog"/>
    </endButton>
</Dialog>

</Page>
</mvc:View>